{
  "name": "dependabot-npm-force-overrides",
  "version": "0.0.0",
  "private": true,
  "description": "GitHub Action scaffold for enforcing npm override policy on Dependabot transitive dependency PRs.",
  "license": "MIT",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.js",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "ci": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "semver": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^24.0.0",
    "@types/semver": "^7.7.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.1"
  },
  "engines": {
    "node": ">=24"
  }
}
